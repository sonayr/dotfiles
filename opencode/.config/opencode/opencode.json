{
    "$schema": "https://opencode.ai/config.json",
    "provider":{
        "google":{
            "options":{
                "baseURL":"https://generativelanguage.googleapis.com/v1beta/"
            }
        }
    },
    "mcp": {
        "atlassian": {
          "type": "local",
          "command": ["npx","-y", "mcp-remote", "https://mcp.atlassian.com/v1/sse"],
          "enabled": true
        },

        "salesforce-dx": {
           "type": "local",
           "command": ["npx","-y", "@salesforce/mcp",
              "--orgs", "ryanScratch",
              "--toolsets", "orgs,metadata,data,users",
              "--tools", "run_apex_test",
              "--allow-non-ga-tools"],
           "enabled": true
        },
        "granola": {
           "type": "local",
           "command": ["uvx","granola-mcp-server"]
        },
        "obsidian": {
          "type": "local",
          "command": ["npx", "-y", "@mauricio.wolff/mcp-obsidian@latest", "~/Documents/Obsidian"]
        }
  },
  "permission": { "skill": {
      "*": "ask",
    }
  }
}
